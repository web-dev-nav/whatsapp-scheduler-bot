# Local interface the Node server binds to.
HOST=127.0.0.1
PORT=3000

# Keep mutable runtime files outside the git checkout in production.
# Forge example: /home/forge/.whatsapp-scheduler-bot
DATA_DIR=./storage

# Optional overrides. Leave blank unless you need custom paths.
# ACCOUNTS_PATH=/home/forge/.whatsapp-scheduler-bot/accounts.json
# CONFIG_PATH=/home/forge/.whatsapp-scheduler-bot/config.json
# SEND_HISTORY_PATH=/home/forge/.whatsapp-scheduler-bot/send-history.json
# WHATSAPP_AUTH_DIR=/home/forge/.whatsapp-scheduler-bot/.wwebjs_auth
# CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome
